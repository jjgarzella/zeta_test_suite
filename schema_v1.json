{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/hyperelliptic-zeta-test-suite.schema.json",
  "title": "Hyperelliptic Zeta Test Suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["cases"],
  "properties": {
    "cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/testCase" }
    }
  },
  "$defs": {
    "intArray": {
      "type": "array",
      "items": { "type": "integer" }
    },

    "fieldElement": {
      "description": "Either an integer (for a=1) or an integer array representing c0 + c1*t + ...",
      "oneOf": [
        { "type": "integer" },
        {
          "type": "array",
          "items": { "type": "integer" }
        }
      ]
    },

    "polyOverField": {
      "type": "array",
      "items": { "$ref": "#/$defs/fieldElement" }
    },

    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p", "a"],
      "properties": {
        "p": {
          "type": "integer",
          "minimum": 2
        },
        "a": {
          "type": "integer",
          "minimum": 1
        },
        "modulus_coeffs_asc": {
          "$ref": "#/$defs/intArray"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "a": { "const": 1 }
            },
            "required": ["a"]
          },
          "then": {},
          "else": {
            "required": ["modulus_coeffs_asc"]
          }
        }
      ]
    },

    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pretty",
        "x_var",
        "y_var",
        "t_var",
        "h_coeffs_asc",
        "f_coeffs_asc"
      ],
      "properties": {
        "pretty": { "type": "string" },
        "x_var": { "type": "string", "const": "x" },
        "y_var": { "type": "string", "const": "y" },
        "t_var": { "type": "string", "const": "t" },
        "h_coeffs_asc": { "$ref": "#/$defs/polyOverField" },
        "f_coeffs_asc": { "$ref": "#/$defs/polyOverField" }
      }
    },

    "curve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["genus", "model"],
      "properties": {
        "genus": {
          "type": "integer",
          "minimum": 0
        },
        "model": { "$ref": "#/$defs/model" }
      }
    },

    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["Lpoly"],
      "properties": {
        "Lpoly": {
          "type": "object",
          "additionalProperties": false,
          "required": ["coeffs_asc"],
          "properties": {
            "coeffs_asc": {
              "type": "array",
              "items": { "type": "integer" },
              "minItems": 1
            }
          }
        }
      }
    },

    "testCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "field", "curve", "expected", "notes"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "field": { "$ref": "#/$defs/field" },
        "curve": { "$ref": "#/$defs/curve" },
        "expected": { "$ref": "#/$defs/expected" },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "field": {
                "properties": {
                  "a": { "const": 1 }
                },
                "required": ["a"]
              }
            }
          },
          "then": {
            "properties": {
              "curve": {
                "properties": {
                  "model": {
                    "properties": {
                      "h_coeffs_asc": {
                        "type": "array",
                        "items": { "type": "integer" }
                      },
                      "f_coeffs_asc": {
                        "type": "array",
                        "items": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "field": {
                "properties": {
                  "a": {
                    "type": "integer",
                    "minimum": 2
                  }
                },
                "required": ["a"]
              }
            }
          },
          "then": {
            "properties": {
              "curve": {
                "properties": {
                  "model": {
                    "properties": {
                      "h_coeffs_asc": {
                        "type": "array",
                        "items": {
                          "type": "array",
                          "items": { "type": "integer" }
                        }
                      },
                      "f_coeffs_asc": {
                        "type": "array",
                        "items": {
                          "type": "array",
                          "items": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "properties": {
            "expected": {
              "properties": {
                "Lpoly": {
                  "properties": {
                    "coeffs_asc": {
                      "type": "array"
                    }
                  },
                  "required": ["coeffs_asc"]
                }
              },
              "required": ["Lpoly"]
            },
            "curve": {
              "properties": {
                "genus": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": ["genus"]
            }
          }
        }
      ]
    }
  }
}
