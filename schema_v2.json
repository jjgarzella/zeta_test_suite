{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/hyperelliptic-zeta-test-suite-v2.schema.json",
  "title": "Hyperelliptic Zeta Test Suite V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["cases"],
  "properties": {
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/testCase"
      }
    }
  },
  "$defs": {
    "integerString": {
      "type": "string",
      "pattern": "^-?[0-9]+$"
    },
    "integerLike": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "$ref": "#/$defs/integerString"
        }
      ]
    },
    "intArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/integerLike"
      }
    },
    "coeffDomainInteger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "const": "integer"
        }
      }
    },
    "coeffDomainNumberField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "const": "number_field"
        }
      }
    },
    "coeffDomain": {
      "oneOf": [
        {
          "$ref": "#/$defs/coeffDomainInteger"
        },
        {
          "$ref": "#/$defs/coeffDomainNumberField"
        }
      ]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pretty",
        "x_var",
        "y_var",
        "t_var",
        "h_coeffs_asc",
        "f_coeffs_asc"
      ],
      "properties": {
        "pretty": {
          "type": "string"
        },
        "x_var": {
          "type": "string",
          "const": "x"
        },
        "y_var": {
          "type": "string",
          "const": "y"
        },
        "t_var": {
          "type": "string",
          "const": "t"
        },
        "h_coeffs_asc": {
          "$ref": "#/$defs/intArray"
        },
        "f_coeffs_asc": {
          "$ref": "#/$defs/intArray"
        }
      }
    },
    "curve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coeff_domain", "genus", "model"],
      "properties": {
        "coeff_domain": {
          "$ref": "#/$defs/coeffDomain"
        },
        "genus": {
          "type": "integer",
          "minimum": 0
        },
        "model": {
          "$ref": "#/$defs/model"
        }
      }
    },
    "lpoly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coeffs_asc"],
      "properties": {
        "coeffs_asc": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/integerLike"
          },
          "minItems": 1
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p", "Lpoly"],
      "properties": {
        "p": {
          "$ref": "#/$defs/integerLike"
        },
        "Lpoly": {
          "$ref": "#/$defs/lpoly"
        }
      }
    },
    "testCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "curve", "results", "notes"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "curve": {
          "$ref": "#/$defs/curve"
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/result"
          },
          "minItems": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
